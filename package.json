{
  "name": "structured-vibe",
  "private": true,
  "version": "0.1.0",
  "description": "Structured vibe coding — flexible, local-first Spec-Driven Development",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "sdd": "pnpm --filter @structured-vibe/cli exec node ./dist/index.js",
    "package:vscode": "pnpm --filter structured-vibe-sdd run package",
    "publish:npm": "pnpm build && pnpm test && pnpm --filter @structured-vibe/core publish --access public && pnpm --filter @structured-vibe/cli publish --access public",
    "publish:npm:dry": "pnpm --filter @structured-vibe/core publish --dry-run --no-git-checks && pnpm --filter @structured-vibe/cli publish --dry-run --no-git-checks"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harsha09/spec-driven-development.git"
  }
}
