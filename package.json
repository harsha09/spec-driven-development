{
  "name": "structured-vibe-coding",
  "private": true,
  "version": "0.5.2",
  "description": "Structured vibe coding — flexible, local-first Spec-Driven Development",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "test:vscode-ui": "pnpm --filter structured-vibe-sdd run test:ui",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "sdd": "pnpm --filter @structured-vibe-coding/cli exec node ./dist/index.js",
    "package:vscode": "pnpm --filter structured-vibe-sdd run package",
    "test:intellij": "cd packages/intellij && (command -v gradle >/dev/null && gradle test || echo 'Skip IntelliJ tests: install JDK17+ and gradle')",
    "publish:npm": "pnpm build && pnpm test && pnpm --filter @structured-vibe-coding/core publish --access public && pnpm --filter @structured-vibe-coding/cli publish --access public",
    "publish:npm:dry": "pnpm --filter @structured-vibe-coding/core publish --dry-run --no-git-checks && pnpm --filter @structured-vibe-coding/cli publish --dry-run --no-git-checks",
    "version:bump": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/structured-vibe-coding/spec-driven-development.git"
  }
}
