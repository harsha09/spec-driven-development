{
  "name": "structured-vibe-sdd",
  "displayName": "Structured Vibe Coding (SDD)",
  "description": "Local-first Spec-Driven Development for VS Code and Cursor — same engine as the sdd CLI",
  "version": "0.6.2",
  "publisher": "structured-vibe-coding",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "sdd",
    "spec-driven",
    "structured vibe",
    "ai coding",
    "workflow",
    "spec driven development"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.sdd/config.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "structuredVibe.init",
        "title": "SDD: Initialize in Workspace",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.new",
        "title": "SDD: New Change",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.status",
        "title": "SDD: Show Status",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.next",
        "title": "SDD: Next Stage",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.skip",
        "title": "SDD: Skip Stage",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.use",
        "title": "SDD: Switch Workflow",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.gateApprove",
        "title": "SDD: Approve Gate",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.gateWaive",
        "title": "SDD: Waive Gate",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.verify",
        "title": "SDD: Local Verify",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.complete",
        "title": "SDD: Complete Change",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.workflows",
        "title": "SDD: List Workflows",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.agent",
        "title": "SDD: Copy Agent Handoff",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.checkout",
        "title": "SDD: Switch Active Change",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.refresh",
        "title": "SDD: Refresh",
        "icon": "$(refresh)",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.openChangeFolder",
        "title": "SDD: Open Change Folder",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.agentsInstall",
        "title": "SDD: Install AI Agent Integration",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.agentsRefresh",
        "title": "SDD: Refresh Agent Context",
        "category": "Structured Vibe"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "structuredVibe",
          "title": "Structured Vibe",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "structuredVibe": [
        {
          "id": "structuredVibe.stages",
          "name": "Change & Stages"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "structuredVibe.refresh",
          "when": "view == structuredVibe.stages",
          "group": "navigation"
        },
        {
          "command": "structuredVibe.new",
          "when": "view == structuredVibe.stages",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Structured Vibe Coding",
      "properties": {
        "structuredVibe.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the SDD stage tree when files under changes/ or .sdd/ change"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test:ui": "pnpm run build && pnpm run compile-tests && node out/test/runTest.js",
    "test:all": "pnpm run test:unit && pnpm run test:ui",
    "package": "pnpm run build && vsce package --no-dependencies",
    "publish:vsce": "pnpm run build && vsce publish --no-dependencies",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "@structured-vibe-coding/core": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.0",
    "glob": "^11.0.1",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/structured-vibe-coding/spec-driven-development.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/structured-vibe-coding/spec-driven-development/issues"
  },
  "homepage": "https://github.com/structured-vibe-coding/spec-driven-development/tree/main/packages/vscode#readme"
}
