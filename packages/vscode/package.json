{
  "name": "structured-vibe-sdd",
  "displayName": "Structured Vibe Coding (SDD)",
  "description": "Local-first Spec-Driven Development for VS Code and Cursor — same engine as the sdd CLI",
  "version": "0.1.0",
  "publisher": "structured-vibe",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "sdd",
    "spec-driven",
    "structured vibe",
    "ai coding",
    "workflow"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.sdd/config.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "structuredVibe.init",
        "title": "SDD: Initialize in Workspace",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.new",
        "title": "SDD: New Change",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.status",
        "title": "SDD: Show Status",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.next",
        "title": "SDD: Next Stage",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.skip",
        "title": "SDD: Skip Stage",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.use",
        "title": "SDD: Switch Workflow",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.gateApprove",
        "title": "SDD: Approve Gate",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.gateWaive",
        "title": "SDD: Waive Gate",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.verify",
        "title": "SDD: Local Verify",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.complete",
        "title": "SDD: Complete Change",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.workflows",
        "title": "SDD: List Workflows",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.agent",
        "title": "SDD: Copy Agent Handoff",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.checkout",
        "title": "SDD: Switch Active Change",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.refresh",
        "title": "SDD: Refresh",
        "icon": "$(refresh)",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.openArtifact",
        "title": "SDD: Open Artifact",
        "category": "Structured Vibe"
      },
      {
        "command": "structuredVibe.openChangeFolder",
        "title": "SDD: Open Change Folder",
        "category": "Structured Vibe"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "structuredVibe",
          "title": "Structured Vibe",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "structuredVibe": [
        {
          "id": "structuredVibe.stages",
          "name": "Change & Stages"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "structuredVibe.refresh",
          "when": "view == structuredVibe.stages",
          "group": "navigation"
        },
        {
          "command": "structuredVibe.new",
          "when": "view == structuredVibe.stages",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "structuredVibe.openArtifact",
          "when": "view == structuredVibe.stages && viewItem == artifact",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Structured Vibe Coding",
      "properties": {
        "structuredVibe.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the SDD stage tree when files under changes/ or .sdd/ change"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "package": "pnpm run build && vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "@structured-vibe/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/harsha09/spec-driven-development.git",
    "directory": "packages/vscode"
  }
}
