{
  "name": "@structured-vibe-coding/core",
  "version": "0.7.0",
  "description": "Core engine for structured vibe coding (local-first Spec-Driven Development)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "defaults",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "pathe": "^2.0.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/structured-vibe-coding/spec-driven-development.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/structured-vibe-coding/spec-driven-development#readme",
  "bugs": {
    "url": "https://github.com/structured-vibe-coding/spec-driven-development/issues"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "structured-vibe-coding",
    "ai-coding",
    "workflow"
  ]
}
