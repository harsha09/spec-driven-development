    "@structured-vibe/core": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
