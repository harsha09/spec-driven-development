{
  "name": "@structured-vibe/cli",
  "version": "0.1.0",
  "description": "CLI for structured vibe coding (SDD)",
  "type": "module",
  "bin": {
    "sdd": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
