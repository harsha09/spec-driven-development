{
  "name": "@structured-vibe-coding/cli",
  "version": "0.2.1",
  "description": "CLI (sdd) for structured vibe coding — local-first Spec-Driven Development",
  "type": "module",
  "bin": {
    "sdd": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
