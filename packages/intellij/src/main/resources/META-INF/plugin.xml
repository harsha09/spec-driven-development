<idea-plugin>
  <id>coding.structuredvibe.sdd</id>
  <name>Structured Vibe Coding (SDD)</name>
  <vendor email="support@structured-vibe-coding.example" url="https://github.com/structured-vibe-coding/spec-driven-development">
    structured-vibe-coding
  </vendor>
  <description><![CDATA[
    <p>Local-first Spec-Driven Development. Runs the <code>sdd</code> CLI and keeps GitHub Copilot / Claude Code aligned via repo agent files.</p>
    <ul>
      <li>Tools → SDD actions (init, new, status, next, verify, complete)</li>
      <li>Refresh <code>.sdd/active-context.md</code> for Copilot in IntelliJ</li>
      <li>Install <code>.github/</code> + <code>.claude/skills/sdd</code> agent integrations</li>
    </ul>
    <p>Requires <code>sdd</code> on PATH (<code>npm i -g @structured-vibe-coding/cli</code>).</p>
  ]]></description>
  <depends>com.intellij.modules.platform</depends>
  <extensions defaultExtensionNs="com.intellij">
    <notificationGroup id="SDD" displayType="BALLOON"/>
  </extensions>
  <actions>
    <group id="Sdd.ToolsGroup" text="SDD" description="Structured Vibe Coding" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <action id="Sdd.Init" class="coding.structuredvibe.sdd.actions.SddInitAction" text="Initialize SDD" description="sdd init"/>
      <action id="Sdd.New" class="coding.structuredvibe.sdd.actions.SddNewAction" text="New Change" description="sdd new"/>
      <action id="Sdd.Status" class="coding.structuredvibe.sdd.actions.SddStatusAction" text="Status" description="sdd status"/>
      <action id="Sdd.Next" class="coding.structuredvibe.sdd.actions.SddNextAction" text="Next Stage" description="sdd next"/>
      <action id="Sdd.Verify" class="coding.structuredvibe.sdd.actions.SddVerifyAction" text="Local Verify" description="sdd verify"/>
      <action id="Sdd.Complete" class="coding.structuredvibe.sdd.actions.SddCompleteAction" text="Complete Change" description="sdd complete"/>
      <separator/>
      <action id="Sdd.AgentsRefresh" class="coding.structuredvibe.sdd.actions.SddAgentsRefreshAction" text="Refresh Agent Context" description="sdd agents refresh"/>
      <action id="Sdd.AgentsInstall" class="coding.structuredvibe.sdd.actions.SddAgentsInstallAction" text="Install Agent Integrations" description="sdd agents install"/>
    </group>
  </actions>
</idea-plugin>
